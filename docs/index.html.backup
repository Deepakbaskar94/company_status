  <span class="close" onclick="toggleMenu()">✕</span>
</div> -->

<!-- ── Nav ────────────────────────────────────────────────────────────────── -->
<nav aria-label="Main navigation">
  <div class="container nav-inner">
    <a href="#" class="nav-logo">
      <div class="icon">🏭</div>
      Factory<span style="color:var(--primary)">SaaS</span>
    </a>
