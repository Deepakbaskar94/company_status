</nav>

<main>

<!-- ── Hero ───────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Multi-tenant manufacturing ERP platform
        </div>
        <h1>Run inventory, production, payroll, and profitability from <span>one ERP</span></h1>
        <p>Factory SaaS connects sales orders, procurement, work orders, QC, delivery, HR, and finance in one manufacturing system for smart factories.</p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Book a Demo →</a>
        </div>
        <div class="hero-proof">
          <span>✓</span>
          <span><strong>17 modules, role-based access, and free migration</strong></span>
        </div>
        <div class="hero-urgency">
          <strong>Book before the next planning cycle starts</strong>
          <span>We’ll map your current order-to-invoice workflow in one live demo.</span>
        </div>
        <div class="hero-points">
          <div class="hero-point">
            <strong>Inventory and MRP</strong>
            <span>Track stock, batches, shortages, and reorder needs.</span>
          </div>
          <div class="hero-point">
            <strong>Production and Quality</strong>
            <span>Move from sales order to work order to QC to delivery.</span>
          </div>
          <div class="hero-point">
            <strong>Payroll and Finance</strong>
            <span>Keep wages, invoicing, receivables, and costs connected.</span>
          </div>
          <div class="hero-point">
            <strong>Multi-unit visibility</strong>
            <span>Manage multiple factories with isolated tenant data.</span>
          </div>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="num">17</div>
            <div class="lbl">Connected ERP modules</div>
          </div>
          <div class="hero-stat">
            <div class="num">1</div>
            <div class="lbl">Sales to invoice workflow</div>
          </div>
          <div class="hero-stat">
            <div class="num">Free</div>
            <div class="lbl">Onboarding and migration</div>
          </div>
        </div>
      </div>

      <!-- Product Screenshot -->
      <div class="hero-visual">
        <div class="hero-visual-head">
          <div>
            <h3>Inside the actual ERP dashboard</h3>
            <p>Finance, maintenance, attendance, inventory, and operations in one real product workspace.</p>
          </div>
        </div>
        <div class="hero-screen">
          <img src="dashboard-screenshot.png" alt="Factory SaaS dashboard showing finance, maintenance, attendance, inventory, and operational data" />
        </div>
        <div class="hero-screen-note">
          <div class="hero-screen-chip">
            <strong>One-click exports</strong>
            Faster reporting without collecting files manually.
          </div>
          <div class="hero-screen-chip">
            <strong>Cross-functional visibility</strong>
            Finance, maintenance, and operations stay in one view.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Platform Snapshot ─────────────────────────────────────────────────── -->
<section class="section platform-strip" id="overview">
  <div class="container">
    <div class="platform-grid">
      <div class="platform-card">
        <div class="label">Coverage</div>
        <h3>17 connected modules</h3>
        <p>HR, inventory, procurement, production, QC, finance, costing, logistics, and dashboards work as one platform instead of separate tools.</p>
      </div>
      <div class="platform-card">
        <div class="label">Deployment</div>
        <h3>Multi-tenant SaaS for factories</h3>
        <p>Each company stays isolated with its own data, users, and module setup while leadership keeps clean operational oversight.</p>
      </div>
      <div class="platform-card">
        <div class="label">Control</div>
        <h3>Role-based access by team</h3>
        <p>Admins, production managers, procurement teams, finance, HR, and warehouse staff get only the visibility and actions they need.</p>
      </div>
      <div class="platform-card">
        <div class="label">Automation</div>
        <h3>Sales order to invoice flow</h3>
        <p>Connect sales orders, BOMs, work orders, QC, delivery challans, invoicing, and profitability tracking in one workflow.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Problem ──────────────────────────────────────────────────────────────── -->
<section class="section" id="problem" style="background:#f8fafc;">
  <div class="container">
    <div class="center">
      <div class="tag">Problems We Solve</div>
      <h2 class="section-title">Manufacturing operations break down when systems stay disconnected</h2>
      <p class="section-sub" style="max-width:760px;margin:0 auto;">Factory SaaS is built for the problems that happen when inventory, production, procurement, quality, HR, and finance all live in separate tools.</p>
    </div>
    <div class="problem-grid">
      <div class="problem-card">
        <div class="p-icon">📦</div>
        <h3>Inventory decisions are reactive</h3>
        <p>Manual stock tracking creates shortages, overstocks, and weak material planning.</p>
      </div>
      <div class="problem-card">
        <div class="p-icon">🏭</div>
        <h3>Production visibility is weak</h3>
        <p>Teams miss deadlines because work orders, progress, and bottlenecks are hard to track in one place.</p>
      </div>
      <div class="problem-card">
        <div class="p-icon">🚚</div>
        <h3>Procurement is scattered</h3>
        <p>Requests, purchase orders, receipts, and vendor coordination get buried across sheets, calls, and emails.</p>
      </div>
      <div class="problem-card">
        <div class="p-icon">🧪</div>
        <h3>Quality issues surface late</h3>
        <p>Without structured QC, defects are found too late and create scrap, rework, and unhappy customers.</p>
      </div>
      <div class="problem-card">
        <div class="p-icon">💸</div>
        <h3>Costs and margins stay unclear</h3>
        <p>Factories struggle to connect production, payroll, procurement, and actual profitability.</p>
      </div>
      <div class="problem-card">
        <div class="p-icon">🏢</div>
        <h3>Multiple units are hard to manage</h3>
        <p>Teams end up using separate systems and lose consolidated oversight across facilities.</p>
      </div>
    </div>
    <div class="solution-strip">
      <div>
        <h3>One platform connects the whole manufacturing loop</h3>
        <p>Sales orders, procurement, production, quality, delivery, invoicing, payroll, and reporting stay connected instead of living in separate systems.</p>
      </div>
      <div class="solution-list">
        <div class="solution-item"><strong>Inventory</strong> links to MRP, PRs, POs, and production.</div>
        <div class="solution-item"><strong>Production</strong> moves from SO to WO to QC to delivery.</div>
        <div class="solution-item"><strong>Finance</strong> stays tied to payroll, invoices, and profitability.</div>
      </div>
    </div>
  </div>
</section>

<!-- ── Features ───────────────────────────────────────────────────────────── -->
<section class="section" id="features">
  <div class="container">
    <div class="center">
      <div class="tag">The Solution</div>
      <h2 class="section-title">Key capabilities that matter on the factory floor</h2>
      <p class="section-sub">Factory SaaS gives operations teams one connected platform instead of isolated software for each department.</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon fi-red">📦</div>
        <h3>Inventory and batch control</h3>
        <p>Track products, raw materials, semi-finished goods, batches, expiry dates, movements, and reservations in real time.</p>
        <div class="feature-proof">Outcome: fewer shortages and cleaner stock control</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-yellow">🛒</div>
        <h3>Procurement and vendor flow</h3>
        <p>Move from purchase request to purchase order to goods receipt to inbound QC with proper vendor visibility.</p>
        <div class="feature-proof">Outcome: better purchasing discipline</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-blue">🏭</div>
        <h3>Production planning and work orders</h3>
        <p>Explode BOMs, release work orders, reserve materials, track progress, and create finished goods with status control.</p>
        <div class="feature-proof">Outcome: stronger production visibility</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-teal">🧪</div>
        <h3>Inward, in-process, and final QC</h3>
        <p>Inspect incoming goods and finished products with pass, fail, and conditional outcomes tied back to inventory batches.</p>
        <div class="feature-proof">Outcome: fewer quality surprises</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-purple">💰</div>
        <h3>Payroll, invoices, and profitability</h3>
        <p>Connect attendance-based payroll, invoicing, payments, costing, and margin tracking in one financial layer.</p>
        <div class="feature-proof">Outcome: clearer cost and margin insights</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon fi-green">📊</div>
        <h3>Dashboards and multi-role visibility</h3>
        <p>Factory owners, production teams, procurement, finance, and HR all get the visibility they need with role-based access.</p>
        <div class="feature-proof">Outcome: better decisions across departments</div>
      </div>
    </div>
  </div>
</section>

<!-- ── Manufacturing Flow ───────────────────────────────────────────────── -->
<section class="section" id="how">
  <div class="container">
    <div class="center">
      <div class="tag">Manufacturing Flow</div>
      <h2 class="section-title">One connected flow from order to invoice</h2>
      <p class="section-sub">The platform keeps inventory, production, quality, delivery, and billing connected across each step.</p>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Sales Order</h3>
        <p>Create or confirm orders and explode BOMs for required materials.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Procurement</h3>
        <p>Raise PRs, create POs, receive goods, and move inbound batches through QC.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Production</h3>
        <p>Release work orders, reserve material, and track work-in-progress on the floor.</p>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <h3>Quality &amp; Delivery</h3>
        <p>Run in-process and final QC, then create delivery challans once goods are ready.</p>
      </div>
      <div class="step">
        <div class="step-num">5</div>
        <h3>Invoice &amp; Profit</h3>
